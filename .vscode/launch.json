{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OpenOCD Debug",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/line-follower.elf",
      "request": "launch",
      "type": "cortex-debug",
      "runToEntryPoint": "main",
      "device": "STM32F407VG",
      "interface": "swd",
      "servertype": "openocd",
      "configFiles": ["openocd.cfg"],
      "gdbPath": "/opt/homebrew/bin/gdb"
    }
  ]
}
